# Uniclos Bloc3 — copier vers .env et definir les valeurs (docker/.env est gitignore)
#   copy .env.example .env

COMPOSE_PROJECT_NAME=uniclos-bloc3
AIRFLOW_UID=50000

# PostgreSQL (service principal + Airflow metadata)
POSTGRES_USER=uniclothes
POSTGRES_PASSWORD=
POSTGRES_DB=uniclothes

# Roles PostgreSQL (RBAC / Grafana datasource)
ANALYST_DB_PASSWORD=
DPO_DB_PASSWORD=
GRAFANA_DB_PASSWORD=

# Airflow UI
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW__CORE__FERNET_KEY=

# MinIO
MINIO_ROOT_USER=uniclos
MINIO_ROOT_PASSWORD=

# Grafana UI
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# dbt (injecte dans Airflow via docker-compose)
DBT_USER=uniclothes
DBT_PASSWORD=
DBT_HOST=postgres
DBT_PORT=5432
DBT_DB=uniclothes
